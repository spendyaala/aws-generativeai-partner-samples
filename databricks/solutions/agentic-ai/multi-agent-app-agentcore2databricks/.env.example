# ─── Databricks Configuration (OAuth M2M) ───
# The SDK automatically exchanges client_id + client_secret for a short-lived
# access token (1 hour) and handles refresh. No PAT needed.
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<service-principal-oauth-secret>
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>
DATABRICKS_CATALOG=finserv_catalog
DATABRICKS_ADMIN_USER=<your-admin-email@example.com>
DATABRICKS_LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# ─── AWS Credentials ───
# Explicit AWS credentials (bypasses environment/profile overrides).
# Must have permissions for: bedrock:InvokeModel, bedrock-agentcore:*
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2

# ─── AgentCore Configuration ───
AGENTCORE_GATEWAY_ID=<gateway-id>
SECRETS_MANAGER_SECRET_NAME=databricks/finserv-analyst/credentials

# ─── Model Configuration ───
# For AgentCore agents (Supervisor, Synthesizer) - via Amazon Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ─── Serving Endpoint Names (Databricks) ───
DATA_ANALYST_ENDPOINT_NAME=finserv-data-analyst
VALIDATOR_ENDPOINT_NAME=finserv-validator
